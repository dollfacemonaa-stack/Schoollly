// ─── AUTH & PROGRESS HOOKS (unchanged except for lesson support) ──────────────
const AuthContext = createContext(null);

function AuthProvider({ children }) {
  const = useState(null);
  const = useState(null);
  const = useState(true);

  useEffect(() => {
    supabase.auth.getSession().then(({ data: { session } }) => {
      setUser(session?.user ?? null);
      if (session?.user) fetchUserAccess(session.user.id);
      else setLoading(false);
    });
    const { data: { subscription } } = supabase.auth.onAuthStateChange((_event, session) => {
      setUser(session?.user ?? null);
      if (session?.user) fetchUserAccess(session.user.id);
      else { setUserAccess(null); setLoading(false); }
    });
    return () => subscription.unsubscribe();
  }, []);

  const fetchUserAccess = async (userId) => {
    const { data } = await supabase.from("user_access").select("*").eq("user_id", userId).single();
    setUserAccess(data);
    setLoading(false);
  };

  const signUp = async (email, password) => {
    const { error } = await supabase.auth.signUp({ email, password });
    return { error };
  };

  const signIn = async (email, password) => {
    const { error } = await supabase.auth.signInWithPassword({ email, password });
    return { error };
  };

  const signOut = async () => { await supabase.auth.signOut(); };

  const hasActiveAccess = (trackId) => {
    if (!userAccess) return false;
    if (userAccess.track_id !== trackId) return false;
    if (userAccess.access_status !== "active") return false;
    if (userAccess.access_expires_at && new Date(userAccess.access_expires_at) < new Date()) return false;
    return true;
  };

  return (
    <AuthContext.Provider value={{ user, userAccess, loading, signUp, signIn, signOut, hasActiveAccess, fetchUserAccess }}>
      {children}
    </AuthContext.Provider>
  );
}

const useAuth = () => useContext(AuthContext);

function useProgress(trackId) {
  const { user } = useAuth();
  const = useState(Object.fromEntries(TRACKS.map(t => )));
  const = useState(false);

  useEffect(() => {
    if (!user || !trackId) return;
    loadProgress(trackId);
  }, );

  const loadProgress = async (tid) => {
    const { data: dbModules } = await supabase.from("modules").select("id, title, sequence_order, lessons").eq("track_id", tid).order("sequence_order");
    if (!dbModules) return;
    const { data: progress } = await supabase.from("user_progress").select("module_id").eq("user_id", user.id);
    const completedIds = new Set(progress?.map(p => p.module_id) ?? []);
    setModuleStates(prev => {
      const updated = prev .map((m, i) => {
        const dbMod = dbModules ;
        const done = dbMod ? completedIds.has(dbMod.id) : false;
        const prevDone = i === 0 || (dbModules && completedIds.has(dbModules .id));
        return { ...m, done, locked: i === 0 ? false : !prevDone };
      });
      return { ...prev, : updated };
    });
  };

  const toggleDone = async (tid, idx) => {
    let wasComplete = false;
    setModuleStates(prev => {
      const updated = prev .map(m => ({ ...m }));
      if (updated .locked) return prev;
      wasComplete = updated .done;
      updated .done = !updated .done;
      if (updated .done && updated ) updated .locked = false;
      if (!updated .done && updated[idx + 1]) updated .locked = true;
      return { ...prev, : updated };
    });
    if (!user) return;
    setSyncing(true);
    const { data: dbMod } = await supabase.from("modules").select("id").eq("track_id", tid).eq("sequence_order", idx + 1).single();
    if (dbMod) {
      if (!wasComplete) {
        await supabase.from("user_progress").upsert({ user_id: user.id, module_id: dbMod.id });
      } else {
        await supabase.from("user_progress").delete().eq("user_id", user.id).eq("module_id", dbMod.id);
      }
    }
    setSyncing(false);
  };

  const getProgress = (tid) => {
    const mods = moduleStates ;
    return Math.round((mods.filter(m => m.done).length / mods.length) * 100);
  };

  return { moduleStates, toggleDone, getProgress, syncing };
}

